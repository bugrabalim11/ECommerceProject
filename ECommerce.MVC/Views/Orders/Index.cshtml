@model List<ECommerce.MVC.DTOs.OrderDtos.ResultOrderDto>

@{
    ViewData["Title"] = "Sipariş Listesi";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    @* Kullanıcılar ikonunu (fa-users) sipariş ikonuna (fa-clipboard-list) çevirdik *@
                    <h4 class="mb-0"><i class="fa-solid fa-clipboard-list me-2"></i>Sistem Siparişleri</h4>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Sipariş No</th>
                                    <th>Müşteri</th>
                                    <th>Tarih</th>
                                    <th>Tutar</th>
                                    <th>Durum</th>
                                    <th class="text-end pe-4">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold">#@item.OrderId</td>
                                            <td>@item.CustomerFullName</td>
                                            <td>@item.OrderDate.ToString("dd.MM.yyyy")</td>
                                            <td class="text-success fw-bold">@item.OrderTotalAmount.ToString("C2")</td>
                                            <td>
                                                @* Bootstrap 5'e uygun rozet (badge) tasarımları *@
                                                @if (item.OrderStatus == "Bekliyor")
                                                {
                                                    <span class="badge bg-warning text-dark">@item.OrderStatus</span>
                                                }
                                                else if (item.OrderStatus == "Onaylandı")
                                                {
                                                    <span class="badge bg-success">@item.OrderStatus</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info text-dark">@item.OrderStatus</span>
                                                }
                                            </td>
                                            <td class="text-end pe-4">
                                                @* Güncelle butonu yerine Detaylar butonunu (fa-eye) koyduk *@
                                                <a asp-controller="Orders" asp-action="OrderDetails" asp-route-id="@item.OrderId" class="btn btn-sm btn-info text-white me-2">
                                                    <i class="fa-solid fa-eye"></i> Detaylar
                                                </a>
                                                <a asp-controller="Orders" asp-action="UpdateOrder" asp-route-id="@item.OrderId" class="btn btn-sm btn-warning text-dark me-2 shadow-sm">
                                                    <i class="fa-solid fa-pen-to-square"></i> Güncelle
                                                </a>
                                                <a asp-controller="Orders" asp-action="DeleteOrder" asp-route-id="@item.OrderId" class="btn btn-sm btn-danger">
                                                    <i class="fa-solid fa-trash"></i> Sil
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            <i>Sistemde henüz kayıtlı sipariş bulunmuyor.</i>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>