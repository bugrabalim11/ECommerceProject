@model ECommerce.MVC.DTOs.UserDtos.UpdateUserDto

@{
    ViewData["Title"] = "Profilim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0"><i class="fa-solid fa-user-pen text-warning me-2"></i>Profil Bilgilerim</h4>
                </div>
                <div class="card-body p-4 bg-white">
                    
                    <form asp-action="Index" asp-controller="Profile" method="post">
                        <input type="hidden" asp-for="UserId" />

                        <div class="mb-3">
                            <label class="form-label fw-bold text-dark"><i class="fa-solid fa-user me-2 text-muted"></i>Adınız</label>
                            <input asp-for="UserName" class="form-control" placeholder="Adınız" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-dark"><i class="fa-solid fa-signature me-2 text-muted"></i>Soyadınız</label>
                            <input asp-for="UserSurname" class="form-control" placeholder="Soyadınız" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-dark"><i class="fa-solid fa-envelope me-2 text-muted"></i>E-Posta Adresiniz</label>
                            <input asp-for="UserEmail" type="email" class="form-control" placeholder="ornek@gmail.com" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark"><i class="fa-solid fa-lock me-2 text-muted"></i>Şifreniz</label>
                            <input asp-for="UserPassword" type="password" class="form-control" placeholder="Şifrenizi giriniz" required />
                            <small class="form-text text-muted mt-1">
                                <i class="fa-solid fa-circle-info me-1 text-warning"></i>Değiştirmek istemiyorsanız mevcut şifrenizi girmelisiniz.
                            </small>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/Home/Index" class="btn btn-outline-secondary rounded-pill px-4 fw-bold">
                                <i class="fa-solid fa-arrow-left me-2"></i>Vazgeç
                            </a>
                            <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold text-dark shadow-sm">
                                <i class="fa-solid fa-floppy-disk me-2"></i>Güncelle
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>