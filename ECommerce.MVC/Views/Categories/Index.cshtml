@model List<ECommerce.MVC.DTOs.CategoryDtos.ResultCategoryDto>

@{
    ViewData["Title"] = "Kategori Listesi";
    // Dünkü güvenlik şifremiz: Cüzdanda anahtar var mı?
    bool isLoggedin = Context.Request.Cookies.ContainsKey("ECommerceToken");
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="fa-solid fa-tags me-2"></i>Kategoriler</h2>

        @if (isLoggedin)
        {
            <a asp-controller="Categories" asp-action="CreateCategory" class="btn btn-success fw-bold shadow-sm">
                <i class="fa-solid fa-plus me-1"></i> Yeni Kategori Ekle
            </a>
        }
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (Model != null && Model.Count > 0)
            {
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Kategori Adı</th>
                            <th>Açıklama</th>
                            @if (isLoggedin)
                            {
                                <th class="text-end pe-4">İşlemler</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle ps-3">@item.CategoryId</td>
                                <td class="align-middle fw-bold text-primary">@item.CategoryName</td>
                                <td class="align-middle text-muted">@item.CategoryDescription</td>

                                @if (isLoggedin)
                                {
                                    <td class="text-end align-middle pe-3">
                                        <a asp-controller="Categories" asp-action="UpdateCategory" asp-route-id="@item.CategoryId" class="btn btn-sm btn-warning fw-bold text-dark me-1">
                                            <i class="fa-solid fa-pen"></i> Güncelle
                                        </a>
                                        <a asp-controller="Categories" asp-action="DeleteCategory" asp-route-id="@item.CategoryId" class="btn btn-sm btn-danger fw-bold" onclick="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?');">
                                            <i class="fa-solid fa-trash"></i> Sil
                                        </a>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <div class="alert alert-warning d-inline-block border-0 shadow-sm">
                        <i class="fa-solid fa-circle-exclamation me-2"></i>Henüz hiç kategori bulunamadı.
                    </div>
                </div>
            }
        </div>
    </div>
</div>