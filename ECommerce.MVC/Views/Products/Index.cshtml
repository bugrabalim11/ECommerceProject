@model List<ECommerce.MVC.DTOs.ProductDtos.ResultProductDto>

@{
    ViewData["Title"] = "Ürünlerimiz";
}

<div class="container mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Mağazadaki Ürünler</h2>
        <span class="badge bg-dark px-3 py-2">Toplam @(Model?.Count ?? 0) Ürün</span>
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @if (Model != null && Model.Count > 0)
        {
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="https://localhost:7107@(item.ImageUrl)" class="card-img-top p-3" alt="@item.ProductName" style="height: 220px; object-fit: contain;">
                        }
                        else
                        {
                            <div class="card-img-top p-3 d-flex align-items-center justify-content-center bg-light" style="height: 220px;">
                                <i class="fa-solid fa-image fa-3x text-secondary"></i>
                            </div>
                        }

                        <div class="card-body text-center d-flex flex-column">
                            <small class="text-uppercase text-muted mb-1">@item.CategoryName</small>
                            <h5 class="card-title fw-bold text-dark mb-3">@item.ProductName</h5>

                            <div class="mt-auto">
                                <h4 class="text-primary fw-bold mb-3">@item.ProductPrice.ToString("C2")</h4>
                                <a href="#" class="btn btn-outline-primary w-100 rounded-pill">
                                    <i class="fa-solid fa-cart-plus me-1"></i>Sepete Ekle
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="alert alert-warning border-0 shadow-sm">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>Henüz hiç ürün bulunamadı veya API bağlantısı kurulamadı.
                </div>
            </div>
        }
    </div>
</div>