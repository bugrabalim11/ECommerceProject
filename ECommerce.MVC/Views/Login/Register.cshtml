@model ECommerce.MVC.DTOs.LoginDtos.RegisterDto
@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = null; // Kayıt sayfasının sade, tam ekran bir tasarım olması için Layout'u kapattık
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kayıt Ol - Mağazam</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center" style="height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-sm border-0 rounded-3">
                    <div class="card-body p-5">
                        <h3 class="text-center mb-4 fw-bold">Yeni Hesap Oluştur</h3>
                        
                        <form asp-action="Register" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            
                            <div class="mb-3">
                                <label class="form-label">Adınız</label>
                                <input type="text" asp-for="UserName" class="form-control" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Soyadınız</label>
                                <input type="text" asp-for="UserSurname" class="form-control" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">E-Posta Adresi</label>
                                <input type="email" asp-for="UserEmail" class="form-control" required />
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Şifre</label>
                                <input type="password" asp-for="UserPassword" class="form-control" required />
                            </div>

                            <button type="submit" class="btn btn-success w-100 fw-bold py-2 mb-3">Kayıt Ol</button>
                        </form>
                        <div class="text-center mt-3">
                            <span class="text-muted">Zaten hesabın var mı?</span>
                            <a asp-controller="Login" asp-action="Index" class="text-decoration-none fw-bold text-success">Giriş Yap</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>