@using ECommerce.MVC.DTOs.OrderItemDtos
@model List<ResultOrderItemDto>

@{
    ViewData["Title"] = "Sipariş Detayları";
}

<div class="container mt-5">
    <div class="row g-4">
        <div class="col-12">
            <div class="bg-light rounded h-100 p-4">
                <h6 class="mb-4">Sipariş İçeriği</h6>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th scope="col">Ürün Adı</th>
                                <th scope="col">Adet</th>
                                <th scope="col">Birim Fiyat</th>
                                <th scope="col">Toplam Fiyat</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Count > 0)
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.Product?.ProductName</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.UnitPrice ₺</td>
                                        <td>@(item.Quantity* item.UnitPrice) ₺</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-danger">Bu siparişe ait herhangi bir ürün bulunamadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <a href="/Orders/Index" class="btn btn-primary mt-3">Siparişlere Geri Dön</a>
            </div>
        </div>
    </div>
</div>
