@model List<ECommerce.MVC.DTOs.UserDtos.ResultUserDto>

@{
    ViewData["Title"] = "Kullanıcı Listesi";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0"><i class="fa-solid fa-users me-2"></i>Sistem Kullanıcıları</h4>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">ID</th>
                                    <th>Ad</th>
                                    <th>Soyad</th>
                                    <th>Email</th>
                                    <th>Kayıt Tarihi</th>
                                    <th class="text-end pe-4">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold">@item.UserId</td>
                                            <td>@item.UserName</td>
                                            <td>@item.UserSurname</td>
                                            <td>@item.UserEmail</td>
                                            @* Sadece gün/ay/yıl kısmını göstermek için ToShortDateString() kullanıyoruz *@
                                            <td>@item.CreatedAt.ToShortDateString()</td>
                                            <td class="text-end pe-4">
                                                <a asp-controller="Users" asp-action="UpdateUser" asp-route-id="@item.UserId" class="btn btn-sm btn-warning me-2">
                                                    <i class="fa-solid fa-pen-to-square"></i> Güncelle
                                                </a>
                                                <a asp-controller="Users" asp-action="DeleteUser" asp-route-id="@item.UserId" class="btn btn-sm btn-danger">
                                                    <i class="fa-solid fa-trash"></i> Sil
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            <i>Sistemde henüz kayıtlı kullanıcı bulunmuyor.</i>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>