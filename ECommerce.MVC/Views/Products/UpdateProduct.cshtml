@model ECommerce.MVC.DTOs.ProductDtos.UpdateProductDto

@{
    ViewData["Title"] = "Ürünü Güncelle";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h4 class="mb-0"><i class="fa-solid fa-pen-to-square me-2"></i>Ürünü Güncelle</h4>
                </div>
                <div class="card-body p-4">

                    <form asp-controller="Products" asp-action="UpdateProduct" method="post">

                        @* BUNA ASLA DOKUNMUYORUZ: API hangi ürünü güncelleyeceğini buradan anlıyor *@
                        <input type="hidden" asp-for="ProductId" />

                        @* 2. Ürün Adı *@
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ürün Adı</label>
                            <input type="text" asp-for="ProductName" class="form-control" required />
                        </div>

                        @* 3. Fiyat ve Kategori *@
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Fiyat (₺)</label>
                                <input type="number" step="0.01" asp-for="ProductPrice" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Kategori</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="@ViewBag.CategoryList" required>
                                    <option value="" disabled>Lütfen Bir Kategori Seçiniz...</option>
                                </select>
                            </div>
                        </div>

                        @* 4. Resim *@
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ürün Resmi (Link)</label>
                            <input type="text" asp-for="ImageUrl" class="form-control" />
                        </div>

                        @* 5. Stok ve Açıklama *@
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Stok Miktarı</label>
                                <input type="number" asp-for="StockQuantity" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Ürün Açıklaması</label>
                                <input type="text" asp-for="ProductDescription" class="form-control" />
                            </div>
                        </div>

                        @* 6. Butonlar *@
                        <div class="d-flex justify-content-between">
                            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
                            <button type="submit" class="btn btn-warning fw-bold px-4">Güncellemeyi Tamamla</button>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>