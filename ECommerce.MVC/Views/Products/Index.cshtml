@model List<ECommerce.MVC.DTOs.ProductDtos.ResultProductDto>

<!DOCTYPE html>
<html>
<head>
    <title>Ürünlerimiz</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">

    <h2 class="text-primary mb-4">Ürün Listesi (Müşteri Salonu)</h2>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Görsel</th>
                <th>Ürün Adı</th>
                <th>Kategori</th>
                <th>Fiyat</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="https://localhost:7107@(item.ImageUrl)" width="80" height="80" style="object-fit:cover;" />
                            }
                            else
                            {
                                <span class="text-muted">Görsel Yok</span>
                            }
                        </td>
                        <td class="align-middle">@item.ProductName</td>
                        <td class="align-middle">@item.CategoryName</td>
                        <td class="align-middle">@item.ProductPrice ₺</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="text-danger text-center">API'den veri çekilemedi. Mutfak kapalı olabilir!</td></tr>
            }
        </tbody>
    </table>

</body>
</html>