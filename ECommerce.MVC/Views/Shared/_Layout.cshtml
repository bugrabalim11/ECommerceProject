<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Benim Mağazam</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom shadow-sm mb-4 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-store text-warning me-2"></i>Benim Mağazam
                </a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold" asp-area="" asp-controller="Category" asp-action="Index">
                                <i class="fa-solid fa-tags me-1"></i> Kategoriler
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white px-3" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold px-3" asp-controller="Products" asp-action="Index">
                                <i class="fa-solid fa-box-open me-1"></i>Ürünlerimiz
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center">
                        <a class="btn btn-outline-warning rounded-pill px-4 fw-bold" asp-controller="Login" asp-action="Index">
                            <i class="fa-solid fa-user-lock me-2"></i>Yönetici Girişi
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white py-4 mt-5">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - <b>Buğra'nın E-Ticaret Projesi</b>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>