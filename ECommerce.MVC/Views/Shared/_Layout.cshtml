<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Benim Mağazam</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom shadow-sm mb-4 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-store text-warning me-2"></i>Benim Mağazam
                </a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-white px-3" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold px-3" asp-controller="Products" asp-action="Index">
                                <i class="fa-solid fa-box-open me-1"></i>Ürünlerimiz
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold px-3" asp-controller="Categories" asp-action="Index">
                                <i class="fa-solid fa-tags me-1"></i> Kategoriler
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white px-3" asp-controller="Orders" asp-action="Index">
                                    <i class="fa-solid fa-clipboard-list"></i> Siparişlerim
                                </a>
                            </li>

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-bold px-3" asp-controller="Users" asp-action="Index">
                                        <i class="fa-solid fa-users-gear me-1"></i> Kullanıcı Yönetimi
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <a class="btn btn-warning rounded-pill px-4 fw-bold text-dark shadow-sm" asp-controller="Baskets" asp-action="Index">
                                <i class="fa-solid fa-cart-shopping me-2"></i>Sepetim
                            </a>

                            <div class="dropdown">
                                <button class="btn btn-outline-light dropdown-toggle rounded-pill px-4" type="button" data-bs-toggle="dropdown">
                                    <i class="fa-solid fa-user-check me-2"></i>@User.Identity.Name
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                    <li>
                                        <a class="dropdown-item fw-bold mb-1" asp-controller="Profile" asp-action="Index">
                                            <i class="fa-solid fa-id-card text-warning me-2"></i>Profilim
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger fw-bold" asp-controller="Login" asp-action="Logout">
                                            <i class="fa-solid fa-right-from-bracket me-2"></i>Çıkış Yap
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-outline-warning rounded-pill px-4 fw-bold" asp-controller="Login" asp-action="Index">
                                <i class="fa-solid fa-user-lock me-2"></i> Giriş Yap
                            </a>
    
                            <a class="btn btn-warning rounded-pill px-4 fw-bold text-dark" asp-controller="Login" asp-action="Register">
                                <i class="fa-solid fa-user-plus me-2"></i> Kayıt Ol
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white py-4 mt-5">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - <b>Buğra'nın E-Ticaret Projesi</b>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({
            icon: 'success',
            title: 'Başarılı!',
            text: '@TempData["SuccessMessage"]',
            confirmButtonColor: '#198754', // Bootstrap success yeşili
            confirmButtonText: 'Tamam'
            });
        </script>
    }
</body>
</html>