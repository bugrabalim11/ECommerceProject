@model ECommerce.MVC.DTOs.OrderDtos.UpdateOrderDto

@{
    ViewData["Title"] = "Sipariş Güncelle";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h4 class="mb-0"><i class="fa-solid fa-pen-to-square me-2"></i>Siparişi Güncelle</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-controller="Orders" asp-action="UpdateOrder" method="post">

                        @* GİZLİ KİMLİKLER (API'ye giderken kaybolmasın diye burada tutulur) *@
                        <input type="hidden" asp-for="OrderId" />
                        <input type="hidden" asp-for="UserId" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Sipariş Durumu</label>
                            @* Durumu elle yazmak yerine Dropdown yapıyoruz *@
                            <select asp-for="OrderStatus" class="form-select">
                                <option value="Bekliyor">Bekliyor</option>
                                <option value="Onaylandı">Onaylandı</option>
                                <option value="Hazırlanıyor">Hazırlanıyor</option>
                                <option value="Kargoya Verildi">Kargoya Verildi</option>
                                <option value="Teslim Edildi">Teslim Edildi</option>
                                <option value="İptal Edildi">İptal Edildi</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Toplam Tutar (₺)</label>
                            @* Tutarı virgüllü girebilmek için step="0.01" ekliyoruz *@
                            <input type="number" step="0.01" class="form-control" asp-for="OrderTotalAmount" />
                        </div>

                        <div class="d-flex justify-content-end mt-4">
                            <a asp-controller="Orders" asp-action="Index" class="btn btn-secondary me-2">İptal</a>
                            <button type="submit" class="btn btn-warning fw-bold text-dark">
                                <i class="fa-solid fa-save me-1"></i> Değişiklikleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>